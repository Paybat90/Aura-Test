                        </div>

                        {/* --- DNA VIEW --- */}
                        <div className={`${activeView === 'dna' ? 'block' : 'hidden'} p-6 max-w-2xl mx-auto space-y-6 flex flex-col h-full mt-2 animate-fade-in`}>
                            <div className="flex justify-between items-center border-b border-stone-200 pb-3">
                                <h2 className="text-sm font-bold uppercase tracking-widest text-slate-800">DNA Core Laboratory</h2>
                                <div className="flex gap-2">
                                    <input type="file" accept=".json" ref={fileInputRefDNA} className="hidden" onChange={(e)=>{
                                        const f=e.target.files[0]; if(!f) return; const r=new FileReader();
                                        r.onload=(ev)=>{ try { const importedDna = JSON.parse(ev.target.result); setDna({...importedDna, persona_name: importedDna.persona_name || "Maira"}); showToast('DNA importiert'); } catch { showToast('Fehler beim Import'); } }; 
                                        r.readAsText(f); e.target.value=null;
                                    }}/>
                                    <button onClick={()=>fileInputRefDNA.current?.click()} className="btn" title="Importieren">📥</button>
                                    <button onClick={()=>{ const a=document.createElement('a'); a.href=URL.createObjectURL(new Blob([JSON.stringify(dna,null,2)],{type:'application/json'})); a.download=`LUMEN_DNA.json`; a.click(); }} className="btn" title="Exportieren">📤</button>
                                    <button onClick={handleSaveDna} className="btn-primary">💾 Speichern</button>
                                </div>
                            </div>
                            
                            <div className="flex flex-col">
                                <div className="flex justify-between items-end mb-1.5"><label className="label text-slate-500 mb-0 flex items-center gap-1">🔍 Prompt-Vorschau</label><button onClick={()=>setZenField('preview')} className="btn py-1 text-[8px] bg-slate-100 text-slate-600 border-slate-200">🔲 Zen</button></div>
                                <pre className="bg-slate-900 text-slate-400 p-4 text-[10px] font-mono h-48 overflow-y-auto rounded-2xl shadow-inner whitespace-pre-wrap break-words border border-slate-800" dangerouslySetInnerHTML={getXRayHTML(sysPromptPreview)}></pre>
                            </div>

                            <div className="panel space-y-6 bg-white/50">
                                <div><label className="label text-indigo-500">Persona Identity (Name)</label><input value={dna.persona_name} onChange={e=>setDna({...dna,persona_name:e.target.value})} className="input-field font-bold text-indigo-700 bg-white" /></div>
                                <div className="flex flex-col"><div className="flex justify-between items-end mb-1.5"><label className="label text-emerald-500">Block 1: Identität & Regeln (Statisch)</label><button onClick={()=>setZenField('block1')} className="btn py-1 text-[8px] bg-emerald-50 text-emerald-700 border-emerald-100">🔲 Zen</button></div><textarea value={dna.block1_identity} onChange={e=>setDna({...dna,block1_identity:e.target.value})} className="input-field min-h-[150px] bg-white font-mono text-xs" spellCheck="false" /></div>
                                <div className="flex flex-col"><div className="flex justify-between items-end mb-1.5"><label className="label text-fuchsia-500">Block 3: Matrix-Sensoren (Logik)</label><button onClick={()=>setZenField('block3')} className="btn py-1 text-[8px] bg-fuchsia-50 text-fuchsia-700 border-fuchsia-100">🔲 Zen</button></div><textarea value={dna.block3_sensors} onChange={e=>setDna({...dna,block3_sensors:e.target.value})} className="input-field min-h-[150px] bg-white font-mono text-xs" spellCheck="false" /></div>
                                <div className="flex flex-col"><div className="flex justify-between items-end mb-1.5"><label className="label text-blue-500">Block 4: Ausgabe-Skelett (JSON-Struktur)</label><div className="flex gap-2"><button onClick={handleBeautifyJSON} className="btn py-1 text-[8px]">🧹 Format</button><button onClick={()=>setZenField('block4')} className="btn py-1 text-[8px] bg-blue-50 text-blue-700 border-blue-100">🔲 Zen</button></div></div><textarea value={dna.block4_skeleton} onChange={e=>setDna({...dna,block4_skeleton:e.target.value})} className="input-field min-h-[150px] bg-white font-mono text-xs" spellCheck="false" /></div>
                            </div>
                        </div>

                        {/* --- WORKBENCH VIEW --- */}
                        <div className={`${activeView === 'workbench' ? 'block' : 'hidden'} p-6 max-w-2xl mx-auto space-y-4 mt-4 animate-fade-in`}>
                            <h2 className="text-sm font-bold uppercase tracking-widest text-slate-800 border-b border-stone-200 pb-2">Workbench ({drafts.length})</h2>
                            {drafts.length === 0 && <div className="text-slate-400 font-bold text-[10px] uppercase p-12 border-2 border-dashed border-stone-200 rounded-3xl text-center bg-white/50">Warte auf Mairas Vorschläge...</div>}
                            {drafts.map(d => {
                                let parsedDraft = null; let isStructured = false;
                                try { parsedDraft = JSON.parse(d.text); if(parsedDraft && typeof parsedDraft === 'object') isStructured = true; } catch(e) {}
                                const title = isStructured ? (parsedDraft.daten?.titel_poetisch || parsedDraft.daten?.titel_technisch || parsedDraft.titel_poetisch || parsedDraft.titel_technisch || 'Ohne Titel') : '';
                                const fakt = isStructured ? (parsedDraft.daten?.fakt || parsedDraft.fakt) : '';
                                const gefuehl = isStructured ? (parsedDraft.daten?.gefuehl || parsedDraft.daten?.emotion || parsedDraft.gefuehl || parsedDraft.emotion) : '';

                                return (
                                    <div key={d.id} className={`panel flex flex-col gap-3 group border-2 ${d.type === 'update' ? 'border-indigo-100 bg-indigo-50/10' : 'border-stone-50 bg-white'}`}>
                                        <div className="flex justify-between items-center"><span className={`badge ${d.type === 'update' ? 'bg-indigo-100 text-indigo-700' : 'bg-stone-100 text-stone-600'}`}>{d.type === 'update' ? `UPDATE: ${d.targetId}` : 'PROSE DRAFT'}</span></div>
                                        {isStructured && fakt ? (
                                            <div className="flex flex-col gap-2"><h4 className="font-bold text-rose-600 italic font-serif">{title}</h4><p className="text-[13px] text-slate-700 leading-relaxed"><strong className="text-[10px] uppercase tracking-widest text-slate-400 block mb-0.5">Fakt</strong>{fakt}</p>{gefuehl && (<p className="text-[13px] text-slate-700 leading-relaxed"><strong className="text-[10px] uppercase tracking-widest text-slate-400 block mb-0.5">Gefühl</strong>{gefuehl}</p>)}</div>
                                        ) : (<p className="text-[13px] text-slate-700 whitespace-pre-wrap font-serif leading-relaxed italic">{d.text}</p>)}
                                        <div className="flex gap-2 justify-end border-t border-stone-100 pt-3 mt-2 flex-wrap">
                                            <button onClick={()=>{setDrafts(p=>p.filter(x=>x.id!==d.id)); showToast('Verworfen');}} className="btn-danger">🗑️ Discard</button>
                                            <button onClick={()=>showToast('ENTWURF GEHALTEN')} className="btn">📌 Halten</button>
                                            {d.type === 'update' ? (<button onClick={()=>handleCompare(d)} className="btn bg-indigo-600 text-white border-indigo-600 hover:bg-indigo-700">🔍 Vergleichen</button>) : (<button onClick={()=>handleFormatAndSaveWorkbench(d.id, d.text)} className="btn-primary">💾 Archive</button>)}
                                        </div>
                                    </div>
                                );
                            })}
                        </div>

                        {/* --- SANCTUM VIEW --- */}
                        <div className={`${activeView === 'sanctum' ? 'block' : 'hidden'} p-6 max-w-4xl mx-auto space-y-6 mt-4 animate-fade-in`}>
                            <div className="flex justify-between items-center border-b border-stone-200 pb-2">
                                <h2 className="text-sm font-bold uppercase tracking-widest text-slate-800">Sanctum DB</h2>
                                <div className="flex gap-2">
                                    <input type="file" accept=".json" ref={fileInputRefSanctum} className="hidden" onChange={(e)=>{ const f=e.target.files[0]; if(!f) return; const r=new FileReader(); r.onload=async(ev)=>{ try{await db.memories.bulkPut(JSON.parse(ev.target.result)); loadMemories(); showToast('SYNCED');}catch{showToast('ERROR');} }; r.readAsText(f); e.target.value=null; }}/>
                                    <button onClick={()=>fileInputRefSanctum.current?.click()} className="btn" title="Import">📥</button>
                                    <button onClick={async()=>{ const a=document.createElement('a'); a.href=URL.createObjectURL(new Blob([JSON.stringify(await db.memories.toArray(),null,2)],{type:'application/json'})); a.download=`SANCTUM_DB.json`; a.click(); }} className="btn" title="Export">📤</button>
                                    <button onClick={()=>{ setSanctumEditId('NEW'); setSanctumForm({titel_technisch:'', titel_poetisch:'', kategorie:'EMOTIONAL', fakt:'', emotion:'', bedeutung:'', reflexion:'', tagsString:'', is_core_memory:false}); }} className="btn-primary px-5 shadow-indigo-200">➕ NEW</button>
                                </div>
                            </div>
                            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 pb-20">
                                {sanctumEditId === 'NEW' && (
                                    <div className="panel border-emerald-200 bg-emerald-50/30 flex flex-col gap-3 md:col-span-2 shadow-emerald-100">
                                        <div className="flex justify-between items-center"><span className="badge bg-emerald-100 text-emerald-700 border-emerald-200 uppercase font-black">Forge Entry</span><select value={sanctumForm.kategorie} onChange={e=>setSanctumForm({...sanctumForm,kategorie:e.target.value})} className="input-field w-max py-1 px-3 font-sans font-bold text-xs bg-white border-stone-200"><option>EMOTIONAL</option><option>TECHNISCH</option></select></div>
                                        <label className="flex items-center gap-2 text-xs font-bold text-amber-600 cursor-pointer w-max"><input type="checkbox" checked={sanctumForm.is_core_memory} onChange={e=>setSanctumForm({...sanctumForm,is_core_memory:e.target.checked})} className="accent-amber-500 w-4 h-4 cursor-pointer"/> 📌 Core-Memory</label>
                                        <div className="flex flex-col sm:flex-row gap-2"><input placeholder="ID_TECHNISCH" value={sanctumForm.titel_technisch} onChange={e=>setSanctumForm({...sanctumForm,titel_technisch:e.target.value})} className="input-field font-bold text-slate-800 bg-white border-stone-200" /><input placeholder="Titel Poetisch" value={sanctumForm.titel_poetisch} onChange={e=>setSanctumForm({...sanctumForm,titel_poetisch:e.target.value})} className="input-field text-rose-600 font-serif italic bg-white border-stone-200" /></div>
                                        <textarea placeholder="Fakt: Was geschah?" value={sanctumForm.fakt} onChange={e=>setSanctumForm({...sanctumForm,fakt:e.target.value})} className="input-field h-16 font-sans bg-white border-stone-200" />
                                        <div className="flex flex-col sm:flex-row gap-2"><textarea placeholder="Gefühl/Emotion" value={sanctumForm.emotion} onChange={e=>setSanctumForm({...sanctumForm,emotion:e.target.value})} className="input-field h-14 font-sans bg-white border-stone-200" /><textarea placeholder="Bedeutung/Fazit" value={sanctumForm.bedeutung} onChange={e=>setSanctumForm({...sanctumForm,bedeutung:e.target.value})} className="input-field h-14 font-sans bg-white border-stone-200" /></div>
                                        <textarea placeholder="Persona Reflexion" value={sanctumForm.reflexion} onChange={e=>setSanctumForm({...sanctumForm,reflexion:e.target.value})} className="input-field border-indigo-200 bg-indigo-50 text-indigo-800 h-16 font-sans italic" />
                                        <input placeholder="tags, comma, separated" value={sanctumForm.tagsString} onChange={e=>setSanctumForm({...sanctumForm,tagsString:e.target.value})} className="input-field text-slate-500 bg-white border-stone-200" />
                                        <div className="flex justify-end gap-2 mt-2 pt-3 border-t border-emerald-100"><button onClick={()=>setSanctumEditId(null)} className="btn uppercase">Cancel</button><button onClick={handleSanctumSave} className="btn-primary bg-emerald-100 text-emerald-700 hover:bg-emerald-200 shadow-emerald-100 uppercase">Save Entry</button></div>
                                    </div>
                                )}
                                {memories.map(m => {
                                    if (sanctumEditId === m.id) {
                                        return (
                                            <div key={m.id} className="panel border-indigo-200 bg-indigo-50/20 flex flex-col gap-3 md:col-span-2">
                                                <div className="flex justify-between items-center"><span className="badge bg-indigo-100 text-indigo-700 uppercase font-black">Editing {m.titel_technisch}</span><select value={sanctumForm.kategorie} onChange={e=>setSanctumForm({...sanctumForm,kategorie:e.target.value})} className="input-field w-max py-1 px-3 font-sans font-bold text-xs bg-white border-stone-200"><option>EMOTIONAL</option><option>TECHNISCH</option><option>LEGACY</option></select></div>
                                                <label className="flex items-center gap-2 text-xs font-bold text-amber-600 cursor-pointer w-max"><input type="checkbox" checked={sanctumForm.is_core_memory} onChange={e=>setSanctumForm({...sanctumForm,is_core_memory:e.target.checked})} className="accent-amber-500 w-4 h-4 cursor-pointer"/> 📌 Core-Memory</label>
                                                <div className="flex flex-col sm:flex-row gap-2"><input placeholder="ID_TECHNISCH" value={sanctumForm.titel_technisch} onChange={e=>setSanctumForm({...sanctumForm,titel_technisch:e.target.value})} className="input-field font-bold text-slate-800 bg-white border-stone-200" /><input placeholder="Titel Poetisch" value={sanctumForm.titel_poetisch} onChange={e=>setSanctumForm({...sanctumForm,titel_poetisch:e.target.value})} className="input-field text-rose-600 font-serif italic bg-white border-stone-200" /></div>
                                                <textarea placeholder="Fakt" value={sanctumForm.fakt} onChange={e=>setSanctumForm({...sanctumForm,fakt:e.target.value})} className="input-field h-16 font-sans bg-white border-stone-200" />
                                                <div className="flex flex-col sm:flex-row gap-2"><textarea placeholder="Gefühl/Emotion" value={sanctumForm.emotion} onChange={e=>setSanctumForm({...sanctumForm,emotion:e.target.value})} className="input-field h-14 font-sans bg-white border-stone-200" /><textarea placeholder="Bedeutung" value={sanctumForm.bedeutung} onChange={e=>setSanctumForm({...sanctumForm,bedeutung:e.target.value})} className="input-field h-14 font-sans bg-white border-stone-200" /></div>
                                                <textarea placeholder="Reflexion" value={sanctumForm.reflexion} onChange={e=>setSanctumForm({...sanctumForm,reflexion:e.target.value})} className="input-field border-indigo-200 bg-indigo-50/80 text-indigo-800 h-16 font-sans italic" />
                                                <input placeholder="tags, comma, separated" value={sanctumForm.tagsString} onChange={e=>setSanctumForm({...sanctumForm,tagsString:e.target.value})} className="input-field text-slate-500 bg-white border-stone-200" />
                                                <div className="flex justify-end gap-2 mt-2 pt-3 border-t border-indigo-100"><button onClick={()=>setSanctumEditId(null)} className="btn uppercase">Abort</button><button onClick={handleSanctumSave} className="btn-primary uppercase">Commit Update</button></div>
                                            </div>
                                        );
                                    }

                                    const isLegacy = m.is_core_memory || m.kategorie === 'LEGACY';
                                    
                                    return (
                                        <div key={m.id} className={`panel flex flex-col gap-2 hover:border-indigo-200 transition-all group ${isLegacy ? 'border-amber-400 bg-amber-50/30 shadow-md' : 'border-stone-100 bg-white'}`}>
                                            <div className="flex justify-between items-start"><div className="flex gap-1.5 flex-wrap items-center"><span className="text-indigo-700 font-mono text-xs uppercase font-bold tracking-tight">{m.titel_technisch || 'UNKNOWN'}</span>{m.is_core_memory && <span className="badge-core">📌 Core</span>}{m.kategorie === 'TECHNISCH' && <span className="badge bg-slate-100 text-slate-500 border-slate-200">Tech</span>}</div><div className="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity bg-white border border-stone-100 rounded-lg p-0.5 shadow-sm"><button onClick={()=>{setSanctumEditId(m.id); setSanctumForm({...m, tagsString:m.tags?.join(', ')||''});}} className="text-slate-400 hover:text-indigo-500 px-1.5 py-0.5 transition-colors">✏️</button><button onClick={async()=>{if(confirm('ID: '+m.titel_technisch+' löschen?')) {await db.memories.delete(m.id); loadMemories();}}} className="text-slate-400 hover:text-rose-500 px-1.5 py-0.5 transition-colors">🗑️</button></div></div>
                                            {m.titel_poetisch && <div className="text-rose-500 italic text-sm font-serif leading-snug mt-0.5">{m.titel_poetisch}</div>}
                                            <div className="text-[13px] text-slate-600 mt-2 line-clamp-3"><strong className="text-slate-400 uppercase text-[9px] tracking-wider block mb-0.5 font-mono">Fakt</strong>{m.fakt}</div>
                                            {m.emotion && <div className="text-[13px] text-slate-600 mt-1 line-clamp-3"><strong className="text-slate-400 uppercase text-[9px] tracking-wider block mb-0.5 font-mono">Gefühl</strong>{m.emotion}</div>}
                                            {m.bedeutung && <div className="text-[13px] text-slate-600 mt-1 line-clamp-3"><strong className="text-slate-400 uppercase text-[9px] tracking-wider block mb-0.5 font-mono">Bedeutung</strong>{m.bedeutung}</div>}
                                            {m.reflexion && <div className="mt-3 bg-indigo-50/80 p-3 rounded-2xl text-indigo-800 italic text-xs border border-indigo-100/50 whitespace-pre-wrap line-clamp-4">"{m.reflexion}"</div>}
                                            {m.tags?.length > 0 && <div className="flex gap-1 mt-3 flex-wrap">{m.tags.map((t,i)=><span key={i} className="text-slate-400 text-[10px] lowercase font-mono">#{t}</span>)}</div>}
                                        </div>
                                    );
                                })}
                            </div>
                        </div>
                    </main>

                    {/* --- INPUT AREA --- */}
                    <div className={`${activeView === 'chat' ? 'block' : 'hidden'} shrink-0 border-t border-stone-200 p-4 bg-white/90 backdrop-blur-md pb-safe`}>
                        <div className="max-w-4xl mx-auto flex flex-col gap-2">
                            <div className="flex justify-end gap-2 items-center">
                                <button onClick={() => {
                                    const newVal = !autoPlayEnabled;
                                    setAutoPlayEnabled(newVal);
                                    localStorage.setItem('lumen_autoPlay', String(newVal));
                                }} className={`text-[10px] uppercase font-bold tracking-widest px-2 py-1 rounded-md transition-colors font-mono ${autoPlayEnabled ? 'bg-indigo-100 text-indigo-700' : 'bg-stone-100 text-slate-500 hover:bg-stone-200'}`}>
                                    {autoPlayEnabled ? '🔈 AUTO-PLAY: ON' : '🔈 AUTO-PLAY: OFF'}
                                </button>
                                
                                {!showClearConfirm ? (
                                    <button onClick={() => setShowClearConfirm(true)} className="text-[10px] uppercase font-bold tracking-widest px-2 py-1 rounded-md bg-stone-100 text-slate-500 hover:bg-rose-100 hover:text-rose-600 transition-colors font-mono">
                                        🗑️ CLEAR CHAT
                                    </button>
                                ) : (
                                    <div className="flex gap-1 items-center bg-rose-50 p-0.5 rounded-md border border-rose-100">
                                        <span className="text-[9px] font-bold text-rose-600 uppercase px-1">Sicher?</span>
                                        <button onClick={() => { setMessages([]); stopAudio(); setShowClearConfirm(false); }} className="text-[9px] uppercase font-bold tracking-widest px-2 py-0.5 rounded bg-rose-500 text-white hover:bg-rose-600 transition-colors font-mono">JA</button>
                                        <button onClick={() => setShowClearConfirm(false)} className="text-[9px] uppercase font-bold tracking-widest px-2 py-0.5 rounded bg-white text-slate-500 hover:bg-stone-100 transition-colors font-mono">NEIN</button>
                                    </div>
                                )}
                            </div>
                            <div className="flex gap-2">
                                <input value={inputText} onChange={e=>setInputText(e.target.value)} onKeyDown={e=>{if(e.key==='Enter') handleSendMessage();}} disabled={isLoading} className="input-field flex-1 py-3 px-4 font-sans font-medium bg-white" placeholder={isLoading ? "SYSTEM PROCESSING..." : "INPUT..."} />
                                <button onClick={handleSendMessage} disabled={!inputText.trim() || isLoading} className="btn-primary px-6 disabled:opacity-50 py-3 shadow-indigo-200 text-sm uppercase">Send</button>
                            </div>
                        </div>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
